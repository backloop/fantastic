	(text "Opt 1:\nRC: R=10k and C=10nF -> freq_cutoff = 1.6kHz\n\nOpt2:\nRC: R=1k and C=100nF -> freq_cutoff = 1.6kHz.\nBetter drive strength, less noise susceptibility\nBetter integration with the pullup resistor of R=10k,\nso that Vlow = 1k/(1k+10k) = 0.45V << 0.3*5V = 1.5V\n"
		(exclude_from_sim no)
		(at 67.056 169.926 0)
		(effects
			(font
				(size 1.27 1.27)
